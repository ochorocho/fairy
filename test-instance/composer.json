{
    "name": "typo3/fair",
    "description": "Integrate fair package manager in TYPO3",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Typo3\\Fair\\": "src/"
        }
    },
    "repositories": {
        "local-packages": {
            "type": "path",
            "url": "../"
        }
    },
    "minimum-stability": "dev",
    "require": {
        "fair/composer-plugin": "@dev",
        "fair/git-updater": "*"
    },
    "config": {
        "allow-plugins": {
            "fair/composer-plugin": true
        }
    },
    "extra": {
        "fair-repositories": {
            "fair": {
                "packages": {
                    "fair/git-updater": "did:plc:afjf7gsjzsqmgc7dlhb553mv"
                }
            }
        }
    }
}
